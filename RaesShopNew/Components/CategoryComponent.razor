    // متدهای انتخاب دسته‌بندی و حذف (همان کد قبلی شما)
    private async Task SelectCategoryOnChange(CreateCategoryDto cat)
{
    if (SelectedCategories.Any(c => c.Id == cat.Id))
        RemoveCategoryAndItsChildren(cat.Id);
    else
        AddCategoryAndItsParents(cat);

    StateHasChanged();
}

private void AddCategoryAndItsParents(CreateCategoryDto category)
{
    if (!SelectedCategories.Any(c => c.Id == category.Id))
        SelectedCategories.Add(category);

    var parentId = category.ParentId;
    while (parentId.HasValue)
    {
        var parent = Categories?.FirstOrDefault(c => c.Id == parentId.Value);
        if (parent == null) break;
        if (!SelectedCategories.Any(c => c.Id == parent.Id))
            SelectedCategories.Add(parent);
        parentId = parent.ParentId;
    }
}

private void RemoveCategoryAndItsChildren(int categoryId)
{
    SelectedCategories.RemoveAll(c => c.Id == categoryId);
    foreach (var child in Categories?.Where(c => c.ParentId == categoryId) ?? Enumerable.Empty<CreateCategoryDto>())
        RemoveCategoryAndItsChildren(child.Id);
}

private bool IsChecked(CreateCategoryDto category) => SelectedCategories.Any(c => c.Id == category.Id);
private bool HasChildren(int categoryId) => Categories?.Any(c => c.ParentId == categoryId) ?? false;

private async Task TryDeleteCategory(CreateCategoryDto category)
{
    if (HasChildren(category.Id))
    {
        await JS.InvokeVoidAsync("alert", "ابتدا زیرمجموعه‌های این دسته‌بندی را حذف کنید.");
        return;
    }

    var confirmed = await JS.InvokeAsync<bool>("confirm", $"آیا از حذف دسته‌بندی «{category.Name}» مطمئن هستید؟");
    if (!confirmed) return;

    var response = await Http.DeleteAsync($"api/categories/{category.Id}");
    if (response.IsSuccessStatusCode)
    {
        Categories?.RemoveAll(c => c.Id == category.Id);
        SelectedCategories.RemoveAll(c => c.Id == category.Id);
        OriginalFilenames.Remove(category.Id);
        await JS.InvokeVoidAsync("showToast", "success", "دسته‌بندی با موفقیت حذف شد.");
        StateHasChanged();
    }
}

private class ApiResponse<T>
{
    public bool Success { get; set; }
    public string? Message { get; set; }
    public T? Data { get; set; }
}

public class UpdateCategoryDto
{
    [Required(ErrorMessage = "نام دسته‌بندی الزامی است")]
    [StringLength(100)]
    public string Name { get; set; } = string.Empty;

    [StringLength(500)]
    public string? Description { get; set; }

    public string? ImageUrl { get; set; }

    public int? ParentId { get; set; } // اضافه کردن این خط
}
}



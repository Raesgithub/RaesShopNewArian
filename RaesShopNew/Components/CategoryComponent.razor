@using Application.Dtos
@using System.Text.Json
@using Application.Helpers.Cpanel
@using System.ComponentModel.DataAnnotations
@using static RaesShopNew.Components.Pages.Store.Detail
@rendermode InteractiveAuto
@inject IJSRuntime JS
@inject HttpClient Http
@inject IConfiguration Configuration



<div class="w-100">
    <div class="mb-4">
        <button class="btn btn-primary" @onclick="OpenAddSidePanel">
            <i class="bi bi-plus-circle"></i> ساخت دسته‌بندی جدید
        </button>
    </div>

    @if (Categories is not null && RendererInfo.IsInteractive)
    {
        @RenderCategories(null, 0)
    }
    else
    {
        <strong>در حال بارگزاری</strong>
    }
</div>

<div class="mt-3">
    <strong>دسته‌های انتخاب شده:</strong>
    @if (SelectedCategories.Any())
    {
        @foreach (var item in SelectedCategories)
        {
            <span class="badge bg-primary mx-1">@item.Name</span>
        }
    }
    else
    {
        <span class="text-muted">هیچ دسته‌ای انتخاب نشده است</span>
    }
</div>

<!-- Side Panel برای افزودن دسته‌بندی -->
@if (ShowAddSidePanel)
{
    <div class="side-panel-container">
        <div class="side-panel-overlay" @onclick="CloseAddSidePanel"></div>
        <div class="side-panel">
            <div class="side-panel-header">
                <h5 class="mb-0">
                    <i class="bi bi-folder-plus me-2"></i>
                    افزودن دسته‌بندی جدید
                </h5>
                <button type="button" class="btn-close btn-close-red" @onclick="CloseAddSidePanel">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-x-lg" viewBox="0 0 16 16">
                        <path d="M2.854 2.854a.5.5 0 0 1 .708 0L8 7.293l4.438-4.439a.5.5 0 0 1 .708.708L8.707 8l4.439 4.438a.5.5 0 1 1-.708.708L8 8.707l-4.438 4.439a.5.5 0 0 1-.708-.708L7.293 8 2.854 3.562a.5.5 0 0 1 0-.708z" />
                    </svg>

                </button>
            </div>
            <div class="side-panel-body">
                @if (!string.IsNullOrEmpty(AddErrorMessage))
                {
                    <div class="alert alert-danger mb-3">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        @AddErrorMessage
                    </div>
                }
                @if (!string.IsNullOrEmpty(AddSuccessMessage))
                {
                    <div class="alert alert-success mb-3">
                        <i class="bi bi-check-circle me-2"></i>
                        @AddSuccessMessage
                    </div>
                }

                <EditForm Model="@NewCategory" OnValidSubmit="SaveNewCategory">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="text-danger mb-3" />

                    <div class="mb-3">
                        <label for="newCategoryName" class="form-label required">نام دسته‌بندی</label>
                        <InputText id="newCategoryName" class="form-control" @bind-Value="NewCategory.Name" />
                        <ValidationMessage For="@(() => NewCategory.Name)" />
                        <small class="form-text text-muted">نام منحصر به فرد برای دسته‌بندی وارد کنید</small>
                    </div>

                    <div class="mb-3">
                        <label for="newCategoryDescription" class="form-label">توضیحات</label>
                        <InputTextArea id="newCategoryDescription" class="form-control" rows="3" @bind-Value="NewCategory.Description" />
                        <small class="form-text text-muted">توضیحات اختیاری درباره این دسته‌بندی</small>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">تصویر دسته‌بندی</label>
                        <div class="card">
                            <div class="card-body">
                                @if (!string.IsNullOrEmpty(AddImageBase64))
                                {
                                    <div class="mb-3">
                                        <p class="text-success mb-2"><i class="bi bi-check-circle me-1"></i>تصویر انتخاب شده:</p>
                                        <div class="d-flex align-items-start gap-3">
                                            <div class="position-relative">
                                                <img src="@AddImageBase64" class="img-thumbnail preview-image" alt="تصویر جدید" />
                                                <button type="button" class="btn btn-sm btn-danger position-absolute translate-middle"
                                                        style="transform: translate(-50%, -50%)!important;top:10px;left:10px" @onclick="ClearNewTempImage" title="حذف تصویر">
                                                    <i class="bi bi-x"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="text-center py-4 border rounded bg-light">
                                        <i class="bi bi-image display-6 text-muted mb-3"></i>
                                        <p class="text-muted mb-3">هنوز تصویری انتخاب نشده است</p>
                                    </div>
                                }

                                <div class="mt-3">
                                    <label class="btn btn-outline-primary w-100 upload-btn">
                                        <i class="bi bi-cloud-upload me-2"></i> انتخاب تصویر
                                        <InputFile id="newImageUpload" class="d-none" accept="image/jpeg,image/png,image/gif,image/webp" OnChange="HandleNewImageUpload" />
                                    </label>
                                    <small class="form-text text-muted d-block mt-2">
                                        فرمت‌های مجاز: JPG, PNG, GIF, WEBP | حداکثر حجم: 5 مگابایت
                                    </small>
                                </div>

                                @if (!string.IsNullOrEmpty(NewUploadError))
                                {
                                    <div class="alert alert-danger mt-2 p-2">
                                        <small><i class="bi bi-exclamation-circle me-1"></i>@NewUploadError</small>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label for="parentCategory" class="form-label">دسته‌بندی والد</label>
                        <select id="parentCategory" class="form-select" @bind="NewCategory.ParentId">
                            <option value="">بدون والد (دسته اصلی)</option>
                            @if (Categories is not null)
                            {
                                @foreach (var category in GetAllCategoriesForSelect(null))
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            }
                        </select>
                        <small class="form-text text-muted">در صورت نیاز، والد این دسته‌بندی را انتخاب کنید</small>
                    </div>

                    <div class="d-flex gap-2 justify-content-end mt-4 pt-3 border-top">
                        <button type="button" class="btn btn-outline-secondary" @onclick="CloseAddSidePanel">
                            <i class="bi bi-x-circle me-1"></i> انصراف
                        </button>
                        <button type="submit" class="btn btn-success" disabled="@_isSaving">
                            @if (_isSaving)
                            {
                                <span><span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>در حال ایجاد...</span>
                            }
                            else
                            {
                                <span><i class="bi bi-check-circle me-1"></i> ایجاد دسته‌بندی</span>
                            }
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<!-- Side Panel برای ویرایش دسته‌بندی -->
@if (ShowEditSidePanel)
{
    <div class="side-panel-container">
        <div class="side-panel-overlay" @onclick="CloseEditSidePanel"></div>
        <div class="side-panel">
            <div class="side-panel-header">
                <h5 class="mb-0">
                    <i class="bi bi-pencil-square me-2"></i>
                    ویرایش دسته‌بندی
                </h5>
                <button type="button" class="btn-close btn-close-red" @onclick="CloseEditSidePanel">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-x-lg" viewBox="0 0 16 16">
                        <path d="M2.854 2.854a.5.5 0 0 1 .708 0L8 7.293l4.438-4.439a.5.5 0 0 1 .708.708L8.707 8l4.439 4.438a.5.5 0 1 1-.708.708L8 8.707l-4.438 4.439a.5.5 0 0 1-.708-.708L7.293 8 2.854 3.562a.5.5 0 0 1 0-.708z" />
                    </svg>

                </button>
            </div>
            <div class="side-panel-body">
                @if (!string.IsNullOrEmpty(EditErrorMessage))
                {
                    <div class="alert alert-danger mb-3">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        @EditErrorMessage
                    </div>
                }
                @if (!string.IsNullOrEmpty(EditSuccessMessage))
                {
                    <div class="alert alert-success mb-3">
                        <i class="bi bi-check-circle me-2"></i>
                        @EditSuccessMessage
                    </div>
                }

                <EditForm Model="@CategoryToEdit" OnValidSubmit="SaveCategoryChanges">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="text-danger mb-3" />

                    <div class="mb-3">
                        <label for="editCategoryName" class="form-label required">نام دسته‌بندی</label>
                        <InputText id="editCategoryName" class="form-control" @bind-Value="CategoryToEdit.Name" />
                        <ValidationMessage For="@(() => CategoryToEdit.Name)" />
                        <small class="form-text text-muted">نام منحصر به فرد برای دسته‌بندی وارد کنید</small>
                    </div>

                    <div class="mb-3">
                        <label for="editCategoryDescription" class="form-label">توضیحات</label>
                        <InputTextArea id="editCategoryDescription" class="form-control" rows="3" @bind-Value="CategoryToEdit.Description" />
                        <small class="form-text text-muted">توضیحات اختیاری درباره این دسته‌بندی</small>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">تصویر دسته‌بندی</label>
                        <div class="card">
                            <div class="card-body">
                                <!-- تصویر فعلی (اصلی با کیفیت بالا) -->
                                <!-- در بخش تصویر فعلی ویرایش -->
                                @if (CategoryToEdit != null && !string.IsNullOrEmpty(CategoryToEdit.ImageUrl))
                                {
                                    <div class="mb-3">
                                        <p class="text-info mb-2"><i class="bi bi-image me-1"></i>تصویر فعلی:</p>
                                        <div class="d-flex align-items-start gap-3">
                                            <div class="position-relative w-100">

                                                <img src="@($"/images/cats/sm-{CategoryToEdit.ImageUrl}")"
                                                     class="img-thumbnail w-100"
                                                     alt="تصویر فعلی"
                                                     style="max-height: 300px; object-fit: contain;" />
                                                <button type="button"
                                                        class="btn btn-sm btn-danger position-absolute translate-middle"
                                                        style="transform: translate(-50%, -50%)!important;top:10px;left:10px"
                                                        @onclick="RemoveCurrentImage"
                                                        title="حذف تصویر فعلی">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>

                                        </div>
                                    </div>
                                }
                                <!-- تصویر جدید آپلود شده -->
                                @if (!string.IsNullOrEmpty(EditImageBase64))
                                {
                                    <div class="mb-3">
                                        <p class="text-success mb-2"><i class="bi bi-check-circle me-1"></i>تصویر جدید انتخاب شده:</p>
                                        <div class="d-flex align-items-start gap-3">
                                            <div class="position-relative">
                                                <img src="@EditImageBase64" class="img-thumbnail preview-image" alt="تصویر جدید" />
                                                <button type="button"
                                                        class="btn btn-sm btn-danger position-absolute top-0 start-100 translate-middle"
                                                        style="transform: translate(-50%, -50%)!important;"
                                                        @onclick="ClearEditTempImage"
                                                        title="حذف تصویر جدید">
                                                    <i class="bi bi-x"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                }

                                @if (string.IsNullOrEmpty(CategoryToEdit?.ImageUrl) && string.IsNullOrEmpty(EditImageBase64))
                                {
                                    <div class="text-center py-4 border rounded bg-light">
                                        <i class="bi bi-image display-6 text-muted mb-3"></i>
                                        <p class="text-muted mb-3">هنوز تصویری انتخاب نشده است</p>
                                    </div>
                                }

                                <div class="mt-3">
                                    <label class="btn btn-outline-primary w-100 upload-btn">
                                        <i class="bi bi-cloud-upload me-2"></i> انتخاب تصویر جدید
                                        <InputFile id="editImageUpload" class="d-none" accept="image/jpeg,image/png,image/gif,image/webp" OnChange="HandleEditImageUpload" />
                                    </label>
                                    <small class="form-text text-muted d-block mt-2">
                                        فرمت‌های مجاز: JPG, PNG, GIF, WEBP | حداکثر حجم: 5 مگابایت
                                    </small>
                                </div>

                                @if (!string.IsNullOrEmpty(EditUploadError))
                                {
                                    <div class="alert alert-danger mt-2 p-2">
                                        <small><i class="bi bi-exclamation-circle me-1"></i>@EditUploadError</small>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label for="editParentCategory" class="form-label">دسته‌بندی والد</label>
                        <select id="editParentCategory" class="form-select" @bind="CategoryToEdit.ParentId">
                            <option value="">بدون والد (دسته اصلی)</option>
                            @if (Categories is not null)
                            {
                                @foreach (var category in GetAllCategoriesForSelect(CategoryToEdit.Id))
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            }
                        </select>
                        <small class="form-text text-muted">در صورت نیاز، والد این دسته‌بندی را انتخاب کنید</small>
                    </div>

                    <div class="d-flex gap-2 justify-content-end mt-4 pt-3 border-top">
                        <button type="button" class="btn btn-outline-secondary" @onclick="CloseEditSidePanel">
                            <i class="bi bi-x-circle me-1"></i> انصراف
                        </button>
                        <button type="submit" class="btn btn-warning" disabled="@_isSavingEdit">
                            @if (_isSavingEdit)
                            {
                                <span><span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>در حال ذخیره...</span>
                            }
                            else
                            {
                                <span><i class="bi bi-save me-1"></i> ذخیره تغییرات</span>
                            }
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {

    public List<CreateCategoryDto>? Categories { get; set; } = null;

    [Parameter] public List<CreateCategoryDto> SelectedCategories { get; set; } = new();
    [Parameter] public List<int> SelectedCats { get; set; }

    // متغیرهای افزودن
    private bool ShowAddSidePanel = false;
    private CreateCategoryDto NewCategory = new();
    private string? AddImageBase64 = null;
    private string? NewUploadError = null;
    private string? AddErrorMessage = null;
    private string? AddSuccessMessage = null;
    private bool _isSaving = false;
    private IBrowserFile? _newSelectedImageFile = null;

    // دیکشنری برای ذخیره نام فایل اصلی (بدون پیشوند xxs-)
    private Dictionary<int, string?> OriginalFilenames { get; set; } = new();

    // متغیرهای ویرایش
    private bool ShowEditSidePanel = false;
    private CreateCategoryDto? CategoryToEdit = null;
    private string? EditImageBase64 = null;
    private string? EditUploadError = null;
    private string? EditErrorMessage = null;
    private string? EditSuccessMessage = null;
    private bool _isSavingEdit = false;
    private IBrowserFile? _editSelectedImageFile = null;
    private bool _removeCurrentImage = false;


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && SelectedCats != null && SelectedCats.Count > 0)
        {
            SetSelectedCategories(SelectedCats);
            StateHasChanged();
        }
    }
    protected override async Task OnInitializedAsync()
    {
        if (Categories is null)
        {
            await LoadCategories();
        }
    }

    private async Task LoadCategories()
    {
        try
        {
            var response = await Http.GetAsync("api/categories");
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var root = JsonDocument.Parse(json).RootElement;

                if (root.TryGetProperty("success", out var successProp) && successProp.GetBoolean())
                {
                    var dataArray = root.GetProperty("data").EnumerateArray();
                    Categories = new List<CreateCategoryDto>();
                    OriginalFilenames.Clear();

                    foreach (var item in dataArray)
                    {
                        var rawImg = item.TryGetProperty("imageUrl", out var imgProp) ? imgProp.GetString() : null;

                        var category = new CreateCategoryDto
                        {
                            Id = item.GetProperty("id").GetInt32(),
                            Name = item.GetProperty("name").GetString() ?? "بدون نام",
                            Description = item.TryGetProperty("description", out var d) ? d.GetString() : null,
                            // تصویر اصلی را ذخیره کنید
                            ImageUrl = rawImg,// GetFullImageUrl(rawImg),
                            ParentId = item.TryGetProperty("parentId", out var p) && p.ValueKind != JsonValueKind.Null
                                ? p.GetInt32()
                                : (int?)null
                        };

                        Categories.Add(category);

                        // if (!string.IsNullOrEmpty(rawImg))
                        // {
                        //     OriginalFilenames[category.Id] = rawImg;
                        // }
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading categories: {ex}");
        }
        finally
        {
            StateHasChanged();
        }
    }
    public void SetSelectedCategories(List<int> categoryIds)
    {
        if (Categories != null && categoryIds?.Any() == true)
        {
            SelectedCategories = Categories
                .Where(c => categoryIds.Contains(c.Id))
                .ToList();
        }
        else
        {
            SelectedCategories = new List<CreateCategoryDto>();
        }
        // StateHasChanged();
    }
    private string? GetFullImageUrl(string? imagename) =>
     string.IsNullOrEmpty(imagename) ? null : $"/images/cats/xxs-{imagename}";

    private string? GetThumbnailImageUrl(string? imagename) =>
        string.IsNullOrEmpty(imagename) ? null : $"/images/cats/sm-{imagename}";

    private string? GetSmallImageUrl(string? imagename) =>
        string.IsNullOrEmpty(imagename) ? null : $"/images/cats/xxs-{imagename}";

    // افزودن
    private void OpenAddSidePanel()
    {
        NewCategory = new CreateCategoryDto();
        AddImageBase64 = null;
        _newSelectedImageFile = null;
        NewUploadError = null;
        AddErrorMessage = null;
        AddSuccessMessage = null;
        ShowAddSidePanel = true;
    }

    private void CloseAddSidePanel()
    {
        ShowAddSidePanel = false;
        NewCategory = new();
        AddImageBase64 = null;
        _newSelectedImageFile = null;
        _isSaving = false;
    }

    private async Task HandleNewImageUpload(InputFileChangeEventArgs e)
    {
        NewUploadError = "";
        if (e.File?.Size > 0)
        {
            _newSelectedImageFile = e.File;
            var ms = new MemoryStream();
            await e.File.OpenReadStream(maxAllowedSize: long.MaxValue).CopyToAsync(ms);
            AddImageBase64 = $"data:{e.File.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
            StateHasChanged();
        }
    }

    private void ClearNewTempImage()
    {
        AddImageBase64 = null;
        _newSelectedImageFile = null;
    }

    private async Task SaveNewCategory()
    {
        try
        {
            _isSaving = true;
            AddErrorMessage = null;

            string? imageUrl = null;
            if (_newSelectedImageFile != null)
            {
                var fileUpload = new FileUpload();
                var check = fileUpload.CheckBeforeUpload(_newSelectedImageFile, "images/cats",
                    new List<string> { ".jpg", ".png", ".jpeg", ".gif", ".webp" }, 5000);
                if (!check.IsSucces)
                {
                    AddErrorMessage = check.Message;
                    return;
                }

                // اصلاح شده - استفاده از UploadBrowserFile به جای Upload
                var upload = await fileUpload.UploadBrowserFile(_newSelectedImageFile, "images/cats",
                    xxsSize32px: true,
                    smSize320px: true);

                if (!upload.IsSucces)
                {
                    AddErrorMessage = upload.Message;
                    return;
                }
                imageUrl = upload.Filename;
            }

            var dto = new CreateCategoryDto
            {
                Name = NewCategory.Name,
                Description = NewCategory.Description,
                ImageUrl = imageUrl,
                ParentId = NewCategory.ParentId
            };

            var response = await Http.PostAsJsonAsync("api/categories", dto);
            if (response.IsSuccessStatusCode)
            {
                AddSuccessMessage = "دسته‌بندی با موفقیت ایجاد شد.";
                await Task.Delay(1500);
                CloseAddSidePanel();
                await LoadCategories();
            }
            else
            {
                AddErrorMessage = await ParseErrorMessage(await response.Content.ReadAsStringAsync());
            }
        }
        catch (Exception ex)
        {
            AddErrorMessage = $"خطای ناشناخته: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

   
    // ویرایش
    private void OpenEditSidePanel(CreateCategoryDto category)
    {
        CategoryToEdit = new CreateCategoryDto
        {
            Id = category.Id,
            Name = category.Name,
            Description = category.Description,
            ImageUrl = category.ImageUrl,
            ParentId = category.ParentId
        };

        EditImageBase64 = null;
        _editSelectedImageFile = null;
        _removeCurrentImage = false;
        ShowEditSidePanel = true;
    }

    private void CloseEditSidePanel()
    {
        ShowEditSidePanel = false;
        CategoryToEdit = null;
        EditImageBase64 = null;
        _editSelectedImageFile = null;
        _removeCurrentImage = false;
    }

    private async Task HandleEditImageUpload(InputFileChangeEventArgs e)
    {
        EditUploadError = "";
        if (e.File?.Size > 0)
        {
            _editSelectedImageFile = e.File;
            var ms = new MemoryStream();
            await e.File.OpenReadStream(maxAllowedSize: long.MaxValue).CopyToAsync(ms);
            EditImageBase64 = $"data:{e.File.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
            _removeCurrentImage = true; // تصویر قبلی جایگزین می‌شود
            StateHasChanged();
        }
    }

    private void ClearEditTempImage()
    {
        EditImageBase64 = null;
        _editSelectedImageFile = null;
        _removeCurrentImage = false;
    }

    private void RemoveCurrentImage()
    {
        _removeCurrentImage = true;
        StateHasChanged();
    }

    private async Task SaveCategoryChanges()
    {
        if (CategoryToEdit == null) return;

        try
        {
            _isSavingEdit = true;
            EditErrorMessage = null;

            var updateDto = new UpdateCategoryDto
            {
                Name = CategoryToEdit.Name,
                Description = CategoryToEdit.Description
            };

            // بررسی حالت‌های مختلف آپلود تصویر
            if (_editSelectedImageFile != null)
            {
                // آپلود تصویر جدید
                var fileUpload = new FileUpload();
                var check = fileUpload.CheckBeforeUpload(_editSelectedImageFile, "images/cats",
                    new List<string> { ".jpg", ".png", ".jpeg", ".gif", ".webp" }, 5000);
                if (!check.IsSucces)
                {
                    EditErrorMessage = check.Message;
                    return;
                }

                // اصلاح شده - استفاده از UploadBrowserFile به جای Upload
                var upload = await fileUpload.UploadBrowserFile(_editSelectedImageFile, "images/cats",
                    xxsSize32px: true,
                    smSize320px: true);

                if (!upload.IsSucces)
                {
                    EditErrorMessage = upload.Message;
                    return;
                }
                updateDto.ImageUrl = upload.Filename;
            }
            else if (_removeCurrentImage)
            {
                // حذف کامل تصویر
                updateDto.ImageUrl = null;
            }
            else
            {
                // استفاده از تصویر فعلی
                updateDto.ImageUrl = CategoryToEdit.ImageUrl;
            }

            // اضافه کردن ParentId به DTO
            updateDto.ParentId = CategoryToEdit.ParentId;

            var response = await Http.PutAsJsonAsync($"api/categories/{CategoryToEdit.Id}", updateDto);
            if (response.IsSuccessStatusCode)
            {
                EditSuccessMessage = "تغییرات با موفقیت ذخیره شد.";
                await Task.Delay(1500);
                CloseEditSidePanel();

                // بارگذاری مجدد لیست
                await LoadCategories();
            }
            else
            {
                EditErrorMessage = await ParseErrorMessage(await response.Content.ReadAsStringAsync());
            }
        }
        catch (Exception ex)
        {
            EditErrorMessage = $"خطای ناشناخته: {ex.Message}";
        }
        finally
        {
            _isSavingEdit = false;
            StateHasChanged();
        }
    }
    private async Task<string> ParseErrorMessage(string content)
    {
        // همان کد قبلی شما...
        try
        {
            var json = JsonDocument.Parse(content).RootElement;
            if (json.TryGetProperty("message", out var msg)) return msg.GetString() ?? "خطا";
            if (json.TryGetProperty("errors", out var errors))
            {
                var list = new List<string>();
                foreach (var err in errors.EnumerateObject())
                    foreach (var val in err.Value.EnumerateArray())
                        list.Add(val.GetString() ?? "");
                return string.Join(" | ", list);
            }
            return "خطا در پردازش پاسخ سرور";
        }
        catch
        {
            return "خطای ناشناخته";
        }
    }

    // بقیه متدها (GetAllCategoriesForSelect, RenderCategories, انتخاب دسته‌ها و ...) بدون تغییر باقی می‌مانند
    // (برای جلوگیری از طولانی شدن، همان کد قبلی شما را نگه دارید)

    private List<CreateCategoryDto> GetAllCategoriesForSelect(int? excludeId = null)
    {
        if (Categories == null || !Categories.Any()) return new();

        var result = new List<CreateCategoryDto>();
        void AddWithIndent(CreateCategoryDto cat, int level)
        {
            if (excludeId.HasValue && cat.Id == excludeId.Value) return;

            var indent = new string('─', level * 3);
            var prefix = level > 0 ? "└" : "";
            var name = level > 0 ? $"{prefix}{indent} {cat.Name}" : $"📁 {cat.Name}";

            result.Add(new CreateCategoryDto { Id = cat.Id, Name = name, ParentId = cat.ParentId });

            foreach (var child in Categories.Where(c => c.ParentId == cat.Id).OrderBy(c => c.Id))
                AddWithIndent(child, level + 1);
        }

        foreach (var root in Categories.Where(c => c.ParentId == null).OrderBy(c => c.Id))
            AddWithIndent(root, 0);

        return result;
    }


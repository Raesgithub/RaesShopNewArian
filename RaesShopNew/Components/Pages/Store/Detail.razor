<script>
    (function () {
        document.addEventListener("keydown", function (e) {
            if (e.key === "Enter") {
                const target = e.target;
                if (target && target.tagName === "INPUT") {
                    const form = target.closest("form");
                    if (form && form.getAttribute("name") === "ProductForm") {
                        e.preventDefault();
                        return false;
                    }
                }
            }
        }, true);
    })();
</script>
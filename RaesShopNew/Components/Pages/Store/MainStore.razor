@page "/"
@using System.Net.Http.Json
@using Application.Services
@using Domain.Models
@inject HttpClient Http
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<div class="store-container">

    <!-- Header box -->
    

    <!-- تبلیغات گوگل (بالای اسلایدر) -->
    <div class="google-ads-top">
        <div class="ad-badge">تبلیغات</div>
        <div class="ad-content">
            <span class="ad-icon">🎯</span>
            <span class="ad-text">فروش ویژه تابستانه تا ۵۰٪ تخفیف</span>
            <button class="ad-btn">مشاهده</button>
        </div>
        <div class="ad-close" onclick="this.parentElement.style.display='none'">✕</div>
    </div>

    <!-- Carousel / Hero -->
    <div class="hero-wrap">
        <button class="hero-nav left" @onclick="HeroPrev">‹</button>
        <div class="hero-slide" @onclick="OpenHeroModal">
            <img src="@GetHeroImage()" alt="hero" />
        </div>
        <button class="hero-nav right" @onclick="HeroNext">›</button>
        <div class="hero-dots">
            @for (int i = 0; i < HeroImages.Count; i++)
            {
                <span class="dot @(i == HeroIndex ? "active" : "")" @onclick="(() => HandleDotClick(i))"></span>
            }
        </div>
    </div>

    <!-- تبلیغات گوگل (بین اسلایدر و محصولات) -->
    <div class="google-ads-middle">
        <div class="ad-grid">
            <div class="ad-card">
                <div class="ad-icon">📱</div>
                <div class="ad-title">موبایل جدید</div>
                <div class="ad-desc">آیفون و سامسونگ با بهترین قیمت</div>
                <div class="ad-link">خرید →</div>
            </div>
            <div class="ad-card">
                <div class="ad-icon">💻</div>
                <div class="ad-title">لپ‌تاپ گیمینگ</div>
                <div class="ad-desc">تخفیف ویژه دانشجویی</div>
                <div class="ad-link">مشاهده →</div>
            </div>
            <div class="ad-card">
                <div class="ad-icon">🎧</div>
                <div class="ad-title">هدفون بی سیم</div>
                <div class="ad-desc">ارسال رایگان</div>
                <div class="ad-link">فروش ویژه →</div>
            </div>
        </div>
    </div>

    <!-- Products -->
    <main class="products-area">
        @if (IsLoading)
        {
            <div class="loading">در حال دریافت محصولات...</div>
        }
        else if (FilteredProducts.Count == 0)
        {
            <div class="no-products">محصولی یافت نشد.</div>
        }
        else
        {
            <div class="products-grid">
                @foreach (var p in PagedProducts)
                {
                    @if (p.IsActive == true)
                    {
                        <div class="product-card">
                            <div class="thumb">
                                @{
                                    var displayImageUrl = GetProductImageUrl(p);
                                }
                                @if (displayImageUrl != "/images/no-image.png")
                                {
                                    <img src="@displayImageUrl"
                                         alt="@p.Name"
                                         loading="lazy"
                                         onerror="this.src='/images/no-image.png'" />
                                }
                                else
                                {
                                    <div class="no-image">بدون تصویر</div>
                                }
                                @if (p.Quantity == 0)
                                {
                                    <span class="badge-out">ناموجود</span>
                                }
                                @if (p.Price > 200000)
                                {
                                    <span class="badge-special">🔥 ویژه</span>
                                }
                            </div>

                            <div class="card-body">
                                <div class="row-top">
                                    <h4 class="product-name">@p.Name</h4>
                                </div>

                                <div class="tags">
                                    @if (p.Tags?.Any() == true)
                                    {
                                        @foreach (var t in p.Tags.Take(3))
                                        {
                                            <span class="tag">@t</span>
                                        }
                                        @if (p.Tags.Count > 3)
                                        {
                                            <span class="tag more">+@(p.Tags.Count - 3)</span>
                                        }
                                    }
                                </div>

                                <div class="card-actions">
                                    <button class="btn-add-to-basket" @onclick="() => AddToBasket(p)">🛒</button>
                                    <button class="btn-buy" @onclick="() => GoToProduct(p.Id)">خرید</button>
                                    <span class="price">
                                        @p.Price.ToString("N0")
                                        <small>تومان</small>
                                    </span>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- Pagination -->
            <div class="pagination-area">
                <button class="page-btn" @onclick="() => ChangePage(CurrentPage - 1)" disabled="@(CurrentPage == 1)">‹</button>
                @for (int i = 1; i <= TotalPages; i++)
                {
                    <button class="page-btn @(i == CurrentPage ? "active" : "")" @onclick="() => ChangePage(i)">@i</button>
                }
                <button class="page-btn" @onclick="() => ChangePage(CurrentPage + 1)" disabled="@(CurrentPage == TotalPages)">›</button>
            </div>
        }
    </main>
</div>

<!-- تبلیغات گوگل (پایین صفحه) -->
<div class="google-ads-footer">
    <div class="ad-banner">
        <div class="banner-text">
            <span>✨ با دیجی‌کالا هوشمند بخرید</span>
            <span class="banner-small">ارسال رایگان + ضمانت بازگشت کالا</span>
        </div>
        <button class="banner-btn">عضویت در خبرنامه</button>
    </div>
</div>

<!-- Hero modal -->
@if (ShowHeroModal)
{
    <div class="modal-backdrop" @onclick="CloseHeroModal">
        <div class="modal-panel" @onclick:stopPropagation>
            <button class="modal-close" @onclick="CloseHeroModal">✕</button>
            <div class="modal-hero">
                <button class="carousel-nav" @onclick="HeroPrev">‹</button>
                <img src="@HeroImages[HeroIndex]" alt="hero" />
                <button class="carousel-nav" @onclick="HeroNext">›</button>
            </div>
        </div>
    </div>
}

<!-- Product modal -->
@if (ShowProductModal && SelectedProduct != null)
{
    <div class="modal-backdrop" @onclick="CloseProductModal">
        <div class="modal-panel product-modal" @onclick:stopPropagation>
            <button class="modal-close" @onclick="CloseProductModal">✕</button>
            <div class="modal-content-flex">
                <div class="modal-thumb">
                    @if (!string.IsNullOrEmpty(SelectedProduct.ImageUrl))
                    {
                        <img src="@GetFullImageUrl(SelectedProduct.ImageUrl)" alt="@SelectedProduct.Name" />
                    }
                </div>
                <div class="modal-info">
                    <h3>@SelectedProduct.Name</h3>
                    <div class="tags">
                        @foreach (var t in SelectedProduct.Tags)
                        {
                            <span class="tag">@t</span>
                        }
                    </div>
                    <div class="modal-actions">
                        <button class="btn-buy" disabled="@(SelectedProduct.Quantity == 0)">افزودن به سبد</button>
                        <button class="btn-close" @onclick="CloseProductModal">بستن</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>

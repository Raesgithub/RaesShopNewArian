@page "/"
@using System.Net.Http.Json
@using Application.Services
@using Domain.Models
@inject HttpClient Http
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<div class="store-container">

    <!-- Header box (sticky top within container) -->
    <div class="top-box">
        <div class="top-left">
            <BasketWidget />
            <div class="brand">
                <div class="brand-title">دیجی‌کالا</div>
                <div class="brand-sub">فروشگاه من</div>
            </div>
        </div>

        <div class="top-center">
            <input class="search-input" placeholder="نام محصول یا برچسب..." @bind="SearchTerm" @onkeydown="HandleSearchKey" />
            <button class="btn-search" @onclick="ApplyFilters">جستجو</button>
        </div>

        <div class="top-right">
            <div class="support-box">
                <div class="support-label">پشتیبانی</div>
                <div class="support-number">119</div>
            </div>
        </div>
    </div>

    <!-- Carousel / Hero under the header box -->
    <div class="hero-wrap">
        <button class="hero-nav left" @onclick="HeroPrev">‹</button>
        <div class="hero-slide" @onclick="OpenHeroModal">
            <img src="@GetHeroImage()" alt="hero" />
        </div>
        <button class="hero-nav right" @onclick="HeroNext">›</button>
        <div class="hero-dots">
            @for (int i = 0; i < HeroImages.Count; i++)
            {
                // از متد HandleDotClick با ارسال مقدار i استفاده کن
                <span class="dot @(i == HeroIndex ? "active" : "")" @onclick="(() => HandleDotClick(i))"></span>
            }
        </div>
    </div>

    <!-- Products (take the remaining area) -->
    <main class="products-area">
        @if (IsLoading)
        {
            <div class="loading">در حال دریافت محصولات...</div>
        }
        else if (FilteredProducts.Count == 0)
        {
            <div class="no-products">محصولی یافت نشد.</div>
        }
        else
        {
            <div class="products-grid">
               
                @foreach (var p in PagedProducts)
                {
                    @if (p.IsActive == true)
                    {
                        <div class="product-card">
                            <!-- Products grid - قسمت تصویر -->
                            <div class="thumb">
                                @{
                                    var displayImageUrl = GetProductImageUrl(p);
                                }
                                @if (displayImageUrl != "/images/no-image.png")
                                {
                                    <img src="@displayImageUrl"
                                         alt="@p.Name"
                                         loading="lazy"
                                         onerror="this.src='/images/no-image.png'" />
                                }
                                else
                                {
                                    <div class="no-image">بدون تصویر</div>
                                }
                                @if (p.Quantity == 0)
                                {
                                    <span class="badge-out">ناموجود</span>
                                }
                            </div>

                            <div class="card-body">
                                <div class="row-top">
                                    <h4 class="product-name">@p.Name</h4>

                                </div>

                                <div class="tags">
                                    @if (p.Tags?.Any() == true)
                                    {
                                        @foreach (var t in p.Tags.Take(3))
                                        {
                                            <span class="tag">@t</span>
                                        }
                                        @if (p.Tags.Count > 3)
                                        {
                                            <span class="tag more">+@(p.Tags.Count - 3)</span>
                                        }
                                    }
                    </div>

                                <div class="card-actions">
                                    <button class="btn-add-to-basket" @onclick="() => AddToBasket(p)">🛒</button>
                                    <button class="btn-buy" @onclick="() => GoToProduct(p.Id)">خرید</button>

                        @code {
                            private void GoToProduct(int productId)
                            {
                                NavigationManager.NavigateTo($"/product/{productId}");
                            }
                        }
                        <span class="price">
                            @p.Price.ToString("N0")
                            <small>تومان</small>
                        </span>


                    </div>
                </div>
            </div>
                    }
                 
                        }
       
                    </div>

        <!-- Pagination -->
        <div class="pagination-area">
            <button class="page-btn" @onclick="() => ChangePage(CurrentPage - 1)" disabled="@(CurrentPage == 1)">‹</button>
            @for (int i = 1; i <= TotalPages; i++)
            {
                <button class="page-btn @(i == CurrentPage ? "active" : "")" @onclick="() => ChangePage(i)">@i</button>
            }
            <button class="page-btn" @onclick="() => ChangePage(CurrentPage + 1)" disabled="@(CurrentPage == TotalPages)">›</button>
        </div>
                }
    </main>
</div>

<!-- Hero modal (optional large view) -->
@if (ShowHeroModal)
{
    <div class="modal-backdrop" @onclick="CloseHeroModal">
        <div class="modal-panel" @onclick:stopPropagation>
            <button class="modal-close" @onclick="CloseHeroModal">✕</button>
            <div class="modal-hero">
                <button class="carousel-nav" @onclick="HeroPrev">‹</button>
                <img src="@HeroImages[HeroIndex]" alt="hero" />
                <button class="carousel-nav" @onclick="HeroNext">›</button>
            </div>
        </div>
    </div>
}

<!-- Product modal (compact) -->
@if (ShowProductModal && SelectedProduct != null)
{
    <div class="modal-backdrop" @onclick="CloseProductModal">
        <div class="modal-panel product-modal" @onclick:stopPropagation>
            <button class="modal-close" @onclick="CloseProductModal">✕</button>
            <div class="modal-content-flex">
                <div class="modal-thumb">
                    @if (!string.IsNullOrEmpty(SelectedProduct.ImageUrl))
                    {
                        <img src="@GetFullImageUrl(SelectedProduct.ImageUrl)" alt="@SelectedProduct.Name" />
                    }
                </div>
                <div class="modal-info">
                    <h3>@SelectedProduct.Name</h3>

                    <div class="tags">
                        @foreach (var t in SelectedProduct.Tags)
                        {
                            <span class="tag">@t</span>
                        }
                    </div>
                    <div class="modal-actions">
                        <button class="btn-buy" disabled="@(SelectedProduct.Quantity == 0)">افزودن به سبد</button>
                        <button class="btn-close" @onclick="CloseProductModal">بستن</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    public class ProductDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public List<int> CategoryIds { get; set; } = new();
        public decimal Price { get; set; }
        public int Quantity { get; set; }
        public string Description { get; set; } = string.Empty;
        public string? ImageUrl { get; set; }
        public List<string>? ImageUrls { get; set; } = new();
        public List<string> Tags { get; set; } = new();
        public bool IsActive { get; set; }
        public DateTime CreatedAt { get; set; }
    }
    [Inject]
    private BasketService Basket { get; set; } = default!;

    private void AddToBasket(ProductDto product)
    {
        var basketItem = new BasketBag
        {
            ProductId = product.Id,
            Code = $"P{product.Id:0000}",  // کد محصول
            Title = product.Name,
            Quantity = 1,
            Price = product.Price,
            ImageUrl = GetProductImageUrl(product)
        };

        Basket.AddToBasket(basketItem);
    }
    private List<ProductDto> Products = new();
    private List<ProductDto> FilteredProducts = new();
    private bool IsLoading = true;

    private string GetProductImageUrl(ProductDto product)
    {
        // اولویت 1: اگر ImageUrls وجود دارد و اولین تصویر را دارد
        if (product.ImageUrls != null && product.ImageUrls.Any())
        {
            var firstImage = product.ImageUrls.First();
            return GetFullImageUrl(firstImage);
        }

        // اولویت 2: اگر ImageUrl وجود دارد
        if (!string.IsNullOrEmpty(product.ImageUrl))
        {
            return GetFullImageUrl(product.ImageUrl);
        }

        // اولویت 3: تصویر پیش‌فرض
        return "/images/no-image.png";
    }
    
    private const int PageSize = 12;
    private int CurrentPage = 1;
    private int TotalPages = 1;
    private int TotalProducts = 0;
    private int ActiveProducts = 0;
    private int TotalInventory = 0;

    private IEnumerable<ProductDto> PagedProducts => FilteredProducts.Skip((CurrentPage - 1) * PageSize).Take(PageSize);

    private string SearchTerm = string.Empty;

    private List<string> HeroImages = new() {
        "/images/cats/sm-1021140410410385977.jpg",
        "/images/cats/sm-1021140410410385977.jpg",
        "/images/cats/sm-1021140410410385977.jpg"
    };
    private int HeroIndex = 0;


    private void HandleDotClick(int index)
    {
        HeroIndex = index;

    }
    private bool ShowHeroModal = false;

    private bool ShowProductModal = false;
    private ProductDto? SelectedProduct;

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        IsLoading = true;
        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<List<ProductDto>>>("api/products");
            if (response != null && response.Success && response.Data != null)
            {
                Products = response.Data;
            }
            else
            {
                Products = SampleProducts();
            }
        }
        catch
        {
            Products = SampleProducts();
        }

        ApplyFilters();
        CalculateStats();
        IsLoading = false;
    }

    private void ApplyFilters()
    {
        FilteredProducts = Products;
        if (!string.IsNullOrWhiteSpace(SearchTerm))
        {
            var term = SearchTerm.Trim();
            FilteredProducts = FilteredProducts
                .Where(p => p.Name.Contains(term, StringComparison.OrdinalIgnoreCase)
                         || (p.Tags?.Any(t => t.Contains(term, StringComparison.OrdinalIgnoreCase)) == true))
                .ToList();
        }
        FilteredProducts = FilteredProducts.OrderByDescending(p => p.CreatedAt).ToList();
        TotalPages = Math.Max(1, (int)Math.Ceiling(FilteredProducts.Count / (double)PageSize));
        CurrentPage = Math.Min(CurrentPage, TotalPages);
    }

    private void CalculateStats()
    {
        TotalProducts = Products.Count;
        ActiveProducts = Products.Count(p => p.IsActive);
        TotalInventory = Products.Sum(p => p.Quantity);
    }

    private void ChangePage(int page)
    {
        if (page < 1) page = 1;
        if (page > TotalPages) page = TotalPages;
        CurrentPage = page;
    }

    private void HandleSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") ApplyFilters();
    }

    private string GetFullImageUrl(string? imageUrl)
    {
        if (string.IsNullOrEmpty(imageUrl))
            return "/images/no-image.png";

        if (imageUrl.StartsWith("http://") || imageUrl.StartsWith("https://"))
            return imageUrl;

        if (imageUrl.StartsWith("/"))
            return imageUrl;

        if (imageUrl.StartsWith("sm-") || imageUrl.StartsWith("md-") || imageUrl.StartsWith("lg-"))
            return $"/images/cats/{imageUrl}";

        if (imageUrl.StartsWith("xl-"))
            return $"/uploads/products/{imageUrl}";

        if (Path.HasExtension(imageUrl))
            return $"/uploads/products/{imageUrl}";

        return $"/uploads/products/xl-{imageUrl}";
    }
    private void HeroNext() => HeroIndex = (HeroIndex + 1) % HeroImages.Count;
    private void HeroPrev() => HeroIndex = (HeroIndex - 1 + HeroImages.Count) % HeroImages.Count;
    private string GetHeroImage() => HeroImages[HeroIndex];
    private void OpenHeroModal() => ShowHeroModal = true;
    private void CloseHeroModal() => ShowHeroModal = false;

    private void OpenProductModal(ProductDto p) { SelectedProduct = p; ShowProductModal = true; }
    private void CloseProductModal() { ShowProductModal = false; SelectedProduct = null; }

    private List<ProductDto> SampleProducts()
    {
        return Enumerable.Range(1, 20).Select(i => new ProductDto
        {
            Id = i,
            Name = $"محصول نمونه {i}",
            Price = 100000 + i * 3000,
            Quantity = (i % 6 == 0) ? 0 : i * 2,
            Description = $"توضیح محصول {i}",
            ImageUrl = (i % 4 == 0) ? null : $"https://via.placeholder.com/400x300?text=Product+{i}",
            Tags = new List<string> { (i % 2 == 0) ? "ویژه" : "پرفروش", "ارسال سریع" },
            IsActive = true,
            CreatedAt = DateTime.Now.AddDays(-i)
        }).ToList();
    }

    public class ApiResponse<T>
    {
        public bool Success { get; set; }
        public string Message { get; set; } = string.Empty;
        public T? Data { get; set; }
    }
}

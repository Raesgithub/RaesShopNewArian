@code {
    public class ProductDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public List<int> CategoryIds { get; set; } = new();
        public decimal Price { get; set; }
        public int Quantity { get; set; }
        public string Description { get; set; } = string.Empty;
        public string? ImageUrl { get; set; }
        public List<string>? ImageUrls { get; set; } = new();
        public List<string> Tags { get; set; } = new();
        public bool IsActive { get; set; }
        public DateTime CreatedAt { get; set; }
    }

    [Inject]
    private BasketService Basket { get; set; } = default!;

    private void AddToBasket(ProductDto product)
    {
        var basketItem = new BasketBag
        {
            ProductId = product.Id,
            Code = $"P{product.Id:0000}",
            Title = product.Name,
            Quantity = 1,
            Price = product.Price,
            ImageUrl = GetProductImageUrl(product)
        };
        Basket.AddToBasket(basketItem);
    }

    private List<ProductDto> Products = new();
    private List<ProductDto> FilteredProducts = new();
    private bool IsLoading = true;

    private string GetProductImageUrl(ProductDto product)
    {
        if (product.ImageUrls != null && product.ImageUrls.Any())
        {
            var firstImage = product.ImageUrls.First();
            return GetFullImageUrl(firstImage);
        }
        if (!string.IsNullOrEmpty(product.ImageUrl))
        {
            return GetFullImageUrl(product.ImageUrl);
        }
        return "/images/no-image.png";
    }

    private const int PageSize = 12;
    private int CurrentPage = 1;
    private int TotalPages = 1;
    private int TotalProducts = 0;
    private int ActiveProducts = 0;
    private int TotalInventory = 0;

    private IEnumerable<ProductDto> PagedProducts => FilteredProducts.Skip((CurrentPage - 1) * PageSize).Take(PageSize);

    private string SearchTerm = string.Empty;

    private List<string> HeroImages = new() {
        "/images/cats/sm-1021140410410385977.jpg",
        "/images/cats/sm-1021140410410385977.jpg",
        "/images/cats/sm-1021140410410385977.jpg"
    };
    private int HeroIndex = 0;

    private void HandleDotClick(int index)
    {
        HeroIndex = index;
    }

    private bool ShowHeroModal = false;
    private bool ShowProductModal = false;
    private ProductDto? SelectedProduct;

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        IsLoading = true;
        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<List<ProductDto>>>("api/products");
            if (response != null && response.Success && response.Data != null)
            {
                Products = response.Data;
            }
            else
            {
                Products = SampleProducts();
            }
        }
        catch
        {
            Products = SampleProducts();
        }

        ApplyFilters();
        CalculateStats();
        IsLoading = false;
    }

    private void ApplyFilters()
    {
        FilteredProducts = Products;
        if (!string.IsNullOrWhiteSpace(SearchTerm))
        {
            var term = SearchTerm.Trim();
            FilteredProducts = FilteredProducts
                .Where(p => p.Name.Contains(term, StringComparison.OrdinalIgnoreCase)
                         || (p.Tags?.Any(t => t.Contains(term, StringComparison.OrdinalIgnoreCase)) == true))
                .ToList();
        }
        FilteredProducts = FilteredProducts.OrderByDescending(p => p.CreatedAt).ToList();
        TotalPages = Math.Max(1, (int)Math.Ceiling(FilteredProducts.Count / (double)PageSize));
        CurrentPage = Math.Min(CurrentPage, TotalPages);
    }

    private void CalculateStats()
    {
        TotalProducts = Products.Count;
        ActiveProducts = Products.Count(p => p.IsActive);
        TotalInventory = Products.Sum(p => p.Quantity);
    }

    private void ChangePage(int page)
    {
        if (page < 1) page = 1;
        if (page > TotalPages) page = TotalPages;
        CurrentPage = page;
    }

    private void HandleSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") ApplyFilters();
    }

    private string GetFullImageUrl(string? imageUrl)
    {
        if (string.IsNullOrEmpty(imageUrl))
            return "/images/no-image.png";

        if (imageUrl.StartsWith("http://") || imageUrl.StartsWith("https://"))
            return imageUrl;

        if (imageUrl.StartsWith("/"))
            return imageUrl;

        if (imageUrl.StartsWith("sm-") || imageUrl.StartsWith("md-") || imageUrl.StartsWith("lg-"))
            return $"/images/cats/{imageUrl}";

        if (imageUrl.StartsWith("xl-"))
            return $"/uploads/products/{imageUrl}";

        if (Path.HasExtension(imageUrl))
            return $"/uploads/products/{imageUrl}";

        return $"/uploads/products/xl-{imageUrl}";
    }

    private void HeroNext() => HeroIndex = (HeroIndex + 1) % HeroImages.Count;
    private void HeroPrev() => HeroIndex = (HeroIndex - 1 + HeroImages.Count) % HeroImages.Count;
    private string GetHeroImage() => HeroImages[HeroIndex];
    private void OpenHeroModal() => ShowHeroModal = true;
    private void CloseHeroModal() => ShowHeroModal = false;
    private void OpenProductModal(ProductDto p) { SelectedProduct = p; ShowProductModal = true; }
    private void CloseProductModal() { ShowProductModal = false; SelectedProduct = null; }
    private void GoToProduct(int productId) => NavigationManager.NavigateTo($"/product/{productId}");

    private List<ProductDto> SampleProducts()
    {
        return Enumerable.Range(1, 20).Select(i => new ProductDto
        {
            Id = i,
            Name = $"محصول نمونه {i}",
            Price = 100000 + i * 3000,
            Quantity = (i % 6 == 0) ? 0 : i * 2,
            Description = $"توضیح محصول {i}",
            ImageUrl = (i % 4 == 0) ? null : $"https://via.placeholder.com/400x300?text=Product+{i}",
            Tags = new List<string> { (i % 2 == 0) ? "ویژه" : "پرفروش", "ارسال سریع" },
            IsActive = true,
            CreatedAt = DateTime.Now.AddDays(-i)
        }).ToList();
    }

    public class ApiResponse<T>
    {
        public bool Success { get; set; }
        public string Message { get; set; } = string.Empty;
        public T? Data { get; set; }
    }
}
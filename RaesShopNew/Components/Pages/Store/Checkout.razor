@page "/checkout"
@using Application.Services
@using Domain.Models
@inject BasketService Basket
@inject NavigationManager NavigationManager
@implements IDisposable
@rendermode InteractiveServer

<div class="checkout-container">

    @if (!Basket.Items.Any() && !OrderPlaced)
    {
        <div class="empty-state">
            <div class="empty-icon">🛒</div>
            <h2>سبد خرید شما خالی است</h2>
            <p>برای خرید به فروشگاه برگردید</p>
            <button class="btn-back" @onclick='() => NavigationManager.NavigateTo("/")'>بازگشت به فروشگاه</button>
        </div>
    }
    else if (OrderPlaced)
    {
        <div class="success-state">
            <div class="success-anim">✅</div>
            <h2>سفارش شما ثبت شد!</h2>
            <p>کد پیگیری: <strong class="order-code">@OrderCode</strong></p>
            <p class="success-sub">پس از تأیید فیش واریزی، سفارش شما پردازش خواهد شد</p>
            <button class="btn-back" @onclick='() => NavigationManager.NavigateTo("/")'>بازگشت به فروشگاه</button>
        </div>
    }
    else
    {
        <div class="page-header">
            <button class="back-btn" @onclick='() => NavigationManager.NavigateTo("/")'>→ بازگشت</button>
            <h1 class="page-title">تکمیل سفارش</h1>
        </div>

        <div class="checkout-grid">

            <!-- ستون چپ -->
            <div class="left-col">

                <!-- کارت مبلغ و شماره کارت -->
                <div class="card pay-card">
                    <div class="card-badge">مرحله ۱</div>
                    <h3 class="card-title">💳 واریز وجه</h3>

                    <div class="amount-box">
                        <div class="amount-label">مبلغ قابل پرداخت</div>
                        <div class="amount-value">@Basket.TotalPrice.ToString("N0")</div>
                        <div class="amount-unit">تومان</div>
                    </div>

                    <div class="card-number-section">
                        <div class="card-number-label">شماره کارت جهت واریز:</div>
                        <div class="card-number-display">
                            <span class="card-num-text">6037-9975-1234-5678</span>
                            <button class="copy-btn" @onclick="CopyCardNumber">
                                @if (Copied) { <span>✓ کپی شد</span> } else { <span>📋 کپی</span> }
                            </button>
                        </div>
                        <div class="card-owner">به نام: علی رضایی</div>
                        <div class="card-bank">بانک ملت</div>
                    </div>

                    <div class="pay-steps">
                        <div class="pay-step">
                            <span class="step-dot">۱</span>
                            <span>مبلغ بالا را به شماره کارت فوق واریز کنید</span>
                        </div>
                        <div class="pay-step">
                            <span class="step-dot">۲</span>
                            <span>تصویر فیش یا رسید واریزی را ذخیره کنید</span>
                        </div>
                        <div class="pay-step">
                            <span class="step-dot">۳</span>
                            <span>فیش را از طریق یکی از کانال‌های زیر ارسال کنید</span>
                        </div>
                    </div>
                </div>

                <!-- کارت ارسال فیش -->
                <div class="card channels-card">
                    <div class="card-badge">مرحله ۲</div>
                    <h3 class="card-title">📤 ارسال فیش واریزی</h3>
                    <p class="channels-desc">تصویر فیش واریزی را از طریق یکی از پیام‌رسان‌های زیر برای ما ارسال کنید:</p>

                    <div class="channels-grid">
                        <a href="https://eitaa.com/your_channel" target="_blank" class="channel-btn eitaa">
                            <div class="channel-icon-wrap">
                                <svg viewBox="0 0 100 100" class="ch-svg">
                                    <circle cx="50" cy="50" r="50" fill="#CC4D1D"/>
                                    <path d="M28 38 Q50 20 72 38 Q80 50 72 62 Q50 80 28 62 Q20 50 28 38Z" fill="none" stroke="white" stroke-width="4"/>
                                    <circle cx="50" cy="50" r="10" fill="white"/>
                                    <line x1="50" y1="28" x2="50" y2="40" stroke="white" stroke-width="4" stroke-linecap="round"/>
                                    <line x1="50" y1="60" x2="50" y2="72" stroke="white" stroke-width="4" stroke-linecap="round"/>
                                    <line x1="28" y1="50" x2="40" y2="50" stroke="white" stroke-width="4" stroke-linecap="round"/>
                                    <line x1="60" y1="50" x2="72" y2="50" stroke="white" stroke-width="4" stroke-linecap="round"/>
                                </svg>
                            </div>
                            <div class="channel-info">
                                <div class="channel-name">ایتا</div>
                                <div class="channel-handle">@@your_shop</div>
                            </div>
                            <span class="channel-arrow">←</span>
                        </a>

                        <a href="https://ble.ir/your_channel" target="_blank" class="channel-btn bale">
                            <div class="channel-icon-wrap">
                                <svg viewBox="0 0 100 100" class="ch-svg">
                                    <circle cx="50" cy="50" r="50" fill="#2196F3"/>
                                    <path d="M25 65 L25 35 Q25 25 35 25 L65 25 Q75 25 75 35 L75 55 Q75 65 65 65 L45 65 L35 78 Z" fill="white"/>
                                    <circle cx="38" cy="45" r="5" fill="#2196F3"/>
                                    <circle cx="50" cy="45" r="5" fill="#2196F3"/>
                                    <circle cx="62" cy="45" r="5" fill="#2196F3"/>
                                </svg>
                            </div>
                            <div class="channel-info">
                                <div class="channel-name">بله</div>
                                <div class="channel-handle">@@your_shop</div>
                            </div>
                            <span class="channel-arrow">←</span>
                        </a>

                        <a href="https://rubika.ir/your_channel" target="_blank" class="channel-btn rubika">
                            <div class="channel-icon-wrap">
                                <svg viewBox="0 0 100 100" class="ch-svg">
                                    <circle cx="50" cy="50" r="50" fill="#00B0A8"/>
                                    <rect x="28" y="28" width="44" height="44" rx="12" fill="white"/>
                                    <rect x="36" y="40" width="12" height="20" rx="4" fill="#00B0A8"/>
                                    <rect x="52" y="33" width="12" height="27" rx="4" fill="#00B0A8"/>
                                </svg>
                            </div>
                            <div class="channel-info">
                                <div class="channel-name">روبیکا</div>
                                <div class="channel-handle">@@your_shop</div>
                            </div>
                            <span class="channel-arrow">←</span>
                        </a>
                    </div>

                    <div class="note-box">
                        <span>⚠️</span>
                        <span>لطفاً هنگام ارسال فیش، کد سفارش خود را نیز ذکر کنید</span>
                    </div>
                </div>

            </div>

            <!-- ستون راست: خلاصه سفارش -->
            <div class="right-col">
                <div class="card summary-card">
                    <h3 class="card-title">🧾 خلاصه سفارش</h3>

                    <div class="order-items">
                        @foreach (var item in Basket.Items)
                        {
                            <div class="order-item">
                                <div class="order-img">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="@item.Title" />
                                    }
                                    else { <span>📦</span> }
                                </div>
                                <div class="order-info">
                                    <div class="order-title">@item.Title</div>
                                    <div class="order-meta">@item.Quantity عدد × @item.Price.ToString("N0") تومان</div>
                                </div>
                                <div class="order-subtotal">@((item.Price * item.Quantity).ToString("N0"))</div>
                            </div>
                        }
                    </div>

                    <div class="summary-divider"></div>

                    <div class="summary-row">
                        <span>تعداد کالا</span>
                        <span>@Basket.TotalItemsCount عدد</span>
                    </div>
                    <div class="summary-row">
                        <span>هزینه ارسال</span>
                        <span class="free-tag">رایگان 🎁</span>
                    </div>

                    <div class="summary-divider"></div>

                    <div class="summary-total">
                        <span>جمع کل</span>
                        <div>
                            <span class="total-num">@Basket.TotalPrice.ToString("N0")</span>
                            <span class="total-unit"> تومان</span>
                        </div>
                    </div>

                    <button class="btn-confirm" @onclick="PlaceOrder" disabled="@IsLoading">
                        @if (IsLoading) { <span>در حال ثبت...</span> }
                        else { <span>✅ ثبت سفارش</span> }
                    </button>
                </div>
            </div>

        </div>
    }
</div>

@code {
    private bool IsLoading = false;
    private bool OrderPlaced = false;
    private bool Copied = false;
    private string OrderCode = "";

    protected override void OnInitialized()
    {
        Basket.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Basket.OnChange -= StateHasChanged;
    }

    private async Task CopyCardNumber()
    {
        Copied = true;
        await Task.Delay(2000);
        Copied = false;
    }

    private async Task PlaceOrder()
    {
        IsLoading = true;
        await Task.Delay(1200);
        OrderCode = $"ORD-{DateTime.Now:yyyyMMdd}-{Random.Shared.Next(1000, 9999)}";
        Basket.ClearBasket();
        OrderPlaced = true;
        IsLoading = false;
    }
}

<style>
    .checkout-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 24px 20px 60px;
        font-family: inherit;
    }

    .page-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 28px;
    }

    .back-btn {
        background: white;
        border: 1px solid #f0e0d0;
        padding: 8px 16px;
        border-radius: 50px;
        color: #78716c;
        cursor: pointer;
        font-size: 0.85rem;
        transition: all 0.2s;
    }
        .back-btn:hover { color: #e85d04; border-color: #e85d04; }

    .page-title {
        font-size: 1.4rem;
        font-weight: 800;
        color: #2d2a24;
        margin: 0;
    }

    /* گرید اصلی */
    .checkout-grid {
        display: grid;
        grid-template-columns: 1fr 360px;
        gap: 24px;
        align-items: start;
        direction: rtl;
    }

    /* کارت‌ها */
    .card {
        background: white;
        border-radius: 20px;
        padding: 24px;
        border: 1px solid #f0e0d0;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        margin-bottom: 20px;
    }

    .card-badge {
        display: inline-block;
        background: linear-gradient(100deg, #e85d04, #ffb347);
        color: white;
        font-size: 0.7rem;
        font-weight: 700;
        padding: 3px 12px;
        border-radius: 50px;
        margin-bottom: 14px;
    }

    .card-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: #2d2a24;
        margin: 0 0 20px 0;
    }

    /* باکس مبلغ */
    .amount-box {
        background: linear-gradient(135deg, #fff8f0, #fef3e2);
        border: 2px solid #ffd9b0;
        border-radius: 16px;
        padding: 20px;
        text-align: center;
        margin-bottom: 20px;
    }

    .amount-label {
        font-size: 0.8rem;
        color: #78716c;
        margin-bottom: 6px;
    }

    .amount-value {
        font-size: 2.2rem;
        font-weight: 800;
        color: #e85d04;
        line-height: 1;
        letter-spacing: -1px;
    }

    .amount-unit {
        font-size: 0.85rem;
        color: #bb3e03;
        margin-top: 4px;
        font-weight: 600;
    }

    /* شماره کارت */
    .card-number-section {
        background: #1a1a2e;
        border-radius: 14px;
        padding: 18px 20px;
        margin-bottom: 20px;
    }

    .card-number-label {
        font-size: 0.72rem;
        color: #aaa;
        margin-bottom: 10px;
    }

    .card-number-display {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 10px;
    }

    .card-num-text {
        font-size: 1.25rem;
        font-weight: 700;
        color: white;
        letter-spacing: 3px;
        font-family: monospace;
        direction: ltr;
    }

    .copy-btn {
        background: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.25);
        color: white;
        padding: 5px 12px;
        border-radius: 8px;
        cursor: pointer;
        font-size: 0.75rem;
        transition: all 0.2s;
        white-space: nowrap;
    }
        .copy-btn:hover { background: rgba(255,255,255,0.25); }

    .card-owner {
        font-size: 0.8rem;
        color: #ddd;
    }

    .card-bank {
        font-size: 0.72rem;
        color: #888;
        margin-top: 2px;
    }

    /* مراحل پرداخت */
    .pay-steps {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .pay-step {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        font-size: 0.85rem;
        color: #4a4540;
    }

    .step-dot {
        background: linear-gradient(135deg, #e85d04, #ffb347);
        color: white;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        font-weight: 700;
        flex-shrink: 0;
        margin-top: 1px;
    }

    /* کانال‌ها */
    .channels-desc {
        font-size: 0.85rem;
        color: #78716c;
        margin-bottom: 18px;
        line-height: 1.7;
    }

    .channels-grid {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-bottom: 16px;
    }

    .channel-btn {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 16px;
        border-radius: 14px;
        text-decoration: none;
        transition: all 0.25s;
        border: 2px solid transparent;
    }

    .channel-btn:hover {
        transform: translateX(-4px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.1);
    }

    .eitaa { background: #fff4f0; border-color: #f5d0c0; }
    .eitaa:hover { border-color: #CC4D1D; }

    .bale { background: #f0f7ff; border-color: #c0d8f5; }
    .bale:hover { border-color: #2196F3; }

    .rubika { background: #f0fffe; border-color: #b0e8e5; }
    .rubika:hover { border-color: #00B0A8; }

    .channel-icon-wrap {
        width: 48px;
        height: 48px;
        flex-shrink: 0;
    }

    .ch-svg {
        width: 100%;
        height: 100%;
        border-radius: 12px;
    }

    .channel-info { flex: 1; }

    .channel-name {
        font-weight: 700;
        font-size: 0.95rem;
        color: #2d2a24;
    }

    .channel-handle {
        font-size: 0.75rem;
        color: #78716c;
        margin-top: 2px;
        direction: ltr;
        text-align: right;
    }

    .channel-arrow {
        font-size: 1.1rem;
        color: #ccc;
        transition: color 0.2s;
    }
    .channel-btn:hover .channel-arrow { color: #e85d04; }

    .note-box {
        background: #fffbea;
        border: 1px solid #fde68a;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 0.8rem;
        color: #92400e;
        display: flex;
        align-items: flex-start;
        gap: 8px;
        line-height: 1.6;
    }

    /* خلاصه سفارش */
    .summary-card { margin-bottom: 0; }

    .order-items {
        display: flex;
        flex-direction: column;
        gap: 12px;
        max-height: 280px;
        overflow-y: auto;
        margin-bottom: 16px;
    }

    .order-item {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .order-img {
        width: 44px;
        height: 44px;
        border-radius: 8px;
        background: #fdf8f2;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        flex-shrink: 0;
        font-size: 1.2rem;
    }
        .order-img img { width: 100%; height: 100%; object-fit: cover; }

    .order-info { flex: 1; min-width: 0; }

    .order-title {
        font-size: 0.82rem;
        font-weight: 600;
        color: #2d2a24;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .order-meta { font-size: 0.7rem; color: #78716c; margin-top: 2px; }

    .order-subtotal {
        font-weight: 700;
        font-size: 0.82rem;
        color: #e85d04;
        white-space: nowrap;
    }

    .summary-divider { height: 1px; background: #f0e0d0; margin: 12px 0; }

    .summary-row {
        display: flex;
        justify-content: space-between;
        font-size: 0.85rem;
        color: #4a4540;
        margin-bottom: 8px;
    }

    .free-tag { color: #16a34a; font-weight: 600; }

    .summary-total {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        font-weight: 700;
        font-size: 1rem;
        color: #2d2a24;
        margin-bottom: 20px;
    }

    .total-num { font-size: 1.3rem; color: #e85d04; font-weight: 800; }
    .total-unit { font-size: 0.8rem; color: #78716c; }

    .btn-confirm {
        width: 100%;
        background: linear-gradient(100deg, #e85d04, #ffb347);
        color: white;
        border: none;
        padding: 14px;
        border-radius: 14px;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.1s;
        box-shadow: 0 4px 14px rgba(232,93,4,0.3);
    }
        .btn-confirm:hover:not(:disabled) { opacity: 0.92; transform: scale(0.99); }
        .btn-confirm:disabled { opacity: 0.6; cursor: not-allowed; }

    /* حالت موفق و خالی */
    .empty-state, .success-state {
        text-align: center;
        padding: 80px 20px;
        background: white;
        border-radius: 24px;
        border: 1px solid #f0e0d0;
        max-width: 480px;
        margin: 40px auto;
    }

    .empty-icon, .success-anim { font-size: 4rem; margin-bottom: 16px; }

    .empty-state h2, .success-state h2 {
        font-size: 1.3rem;
        font-weight: 700;
        color: #2d2a24;
        margin-bottom: 10px;
    }

    .empty-state p, .success-state p { color: #78716c; font-size: 0.9rem; margin-bottom: 6px; }

    .order-code {
        background: #fef3e2;
        color: #e85d04;
        padding: 4px 12px;
        border-radius: 8px;
        font-family: monospace;
        font-size: 1rem;
    }

    .success-sub { font-size: 0.8rem !important; margin-top: 8px !important; }

    .btn-back {
        background: linear-gradient(100deg, #e85d04, #ffb347);
        color: white;
        border: none;
        padding: 11px 28px;
        border-radius: 50px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        margin-top: 20px;
        transition: opacity 0.2s;
    }
        .btn-back:hover { opacity: 0.9; }

    @@media (max-width: 768px) {
        .checkout-grid { grid-template-columns: 1fr; }
        .card-num-text { font-size: 1rem; letter-spacing: 1px; }
    }
</style>
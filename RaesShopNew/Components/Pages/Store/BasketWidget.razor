@using Application.Services
<!-- Components/BasketWidget.razor -->
@inject BasketService Basket

<div class="basket-widget">
    <button class="basket-button" @onclick="ToggleBasket">
        <span class="basket-icon">🛒</span>
        @if (Basket.TotalItemsCount > 0)
        {
            <span class="basket-badge">@Basket.TotalItemsCount</span>
        }
    </button>

    @if (IsOpen)
    {
        <div class="basket-dropdown">
            <div class="basket-header">
                <h3>سبد خرید</h3>
                @if (Basket.Items.Any())
                {
                    <button class="clear-basket" @onclick="ClearBasket">حذف همه</button>
                }
                <button class="close-basket" @onclick="ToggleBasket">✕</button>
            </div>

            @if (!Basket.Items.Any())
            {
                <div class="empty-basket">
                    <span>🛒</span>
                    <p>سبد خرید شما خالی است</p>
                </div>
            }
            else
            {
                <div class="basket-items">
                    @foreach (var item in Basket.Items)
                    {
                        <div class="basket-item">
                            <div class="item-image">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@GetFullImageUrl(item.ImageUrl)" alt="@item.Title" />
                                }
                                else
                                {
                                    <div class="no-image-small">📷</div>
                                }
                            </div>
                            <div class="item-details">
                                <div class="item-code">کد محصول: @item.Code</div>
                                <div class="item-title">@item.Title</div>
                                <div class="item-price-row">
                                    <span class="item-price">@item.Price.ToString("N0") تومان</span>
                                </div>
                                <div class="item-quantity">
                                    <button class="qty-btn" @onclick="() => DecrementQuantity(item.ProductId)">-</button>
                                    <span class="qty-value">@item.Quantity</span>
                                    <button class="qty-btn" @onclick="() => IncrementQuantity(item.ProductId)">+</button>
                                </div>
                            </div>
                            <button class="remove-item" @onclick="() => RemoveItem(item.ProductId)">🗑️</button>
                        </div>
                    }
                </div>
                <div class="basket-footer">
                    <div class="basket-total">
                        <span>مجموع:</span>
                        <span class="total-price">@Basket.TotalPrice.ToString("N0") تومان</span>
                    </div>
                    <button class="checkout-btn">پرداخت</button>
                </div>
            }
        </div>
    }
</div>

@code {
    private bool IsOpen = false;

    protected override void OnInitialized()
    {
        Basket.OnChange += StateHasChanged;
    }

    private void ToggleBasket() => IsOpen = !IsOpen;

    private void RemoveItem(int productId)
    {
        Basket.RemoveFromBasket(productId);
    }

    private void IncrementQuantity(int productId)
    {
        var item = Basket.Items.FirstOrDefault(i => i.ProductId == productId);
        if (item != null)
        {
            Basket.UpdateQuantity(productId, item.Quantity + 1);
        }
    }

    private void DecrementQuantity(int productId)
    {
        var item = Basket.Items.FirstOrDefault(i => i.ProductId == productId);
        if (item != null)
        {
            Basket.UpdateQuantity(productId, item.Quantity - 1);
        }
    }

    private void ClearBasket()
    {
        Basket.ClearBasket();
    }

    private string GetFullImageUrl(string? imageUrl)
    {
        if (string.IsNullOrEmpty(imageUrl))
            return "/images/no-image.png";

        if (imageUrl.StartsWith("http"))
            return imageUrl;

        if (imageUrl.StartsWith("/"))
            return imageUrl;

        return $"/uploads/products/{imageUrl}";
    }
}
<style>
    /* Basket Widget Styles */
    .basket-widget {
        position: relative;
    }

    .basket-button {
        background: #f1f5f9;
        border: none;
        padding: 8px 16px;
        border-radius: 40px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 1.2rem;
        position: relative;
        transition: all 0.2s;
    }

        .basket-button:hover {
            background: #e2e8f0;
        }

    .basket-icon {
        font-size: 1.3rem;
    }

    .basket-badge {
        background: #ef4444;
        color: white;
        border-radius: 50%;
        width: 20px;
        height: 20px;
        font-size: 0.7rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        position: absolute;
        top: -5px;
        right: -5px;
    }

    .basket-dropdown {
        position: absolute;
        top: 48px;
        left: 0;
        width: 380px;
        max-height: 500px;
        background: white;
        border-radius: 16px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        z-index: 1000;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .basket-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 16px;
        border-bottom: 1px solid #e2e8f0;
        background: #f8fafc;
    }

        .basket-header h3 {
            margin: 0;
            font-size: 1.1rem;
        }

    .clear-basket {
        background: none;
        border: none;
        color: #ef4444;
        font-size: 0.8rem;
        cursor: pointer;
    }

    .close-basket {
        background: none;
        border: none;
        font-size: 1.2rem;
        cursor: pointer;
    }

    .basket-items {
        flex: 1;
        overflow-y: auto;
        max-height: 380px;
    }

    .basket-item {
        display: flex;
        gap: 12px;
        padding: 12px;
        border-bottom: 1px solid #f1f5f9;
        position: relative;
    }

    .item-image {
        width: 60px;
        height: 60px;
        background: #f8fafc;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

        .item-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .no-image-small {
        font-size: 1.5rem;
    }

    .item-details {
        flex: 1;
    }

    .item-code {
        font-size: 0.7rem;
        color: #64748b;
        margin-bottom: 2px;
    }

    .item-title {
        font-weight: 600;
        font-size: 0.85rem;
        margin: 4px 0;
    }

    .item-price-row {
        margin-bottom: 6px;
    }

    .item-price {
        font-weight: 700;
        color: #059669;
        font-size: 0.85rem;
    }

    .item-quantity {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .qty-btn {
        background: #f1f5f9;
        border: none;
        width: 24px;
        height: 24px;
        border-radius: 6px;
        cursor: pointer;
        font-weight: bold;
    }

        .qty-btn:hover {
            background: #e2e8f0;
        }

    .qty-value {
        min-width: 24px;
        text-align: center;
        font-weight: 500;
    }

    .remove-item {
        background: none;
        border: none;
        cursor: pointer;
        opacity: 0.5;
        transition: opacity 0.2s;
        font-size: 1.1rem;
    }

        .remove-item:hover {
            opacity: 1;
        }

    .empty-basket {
        text-align: center;
        padding: 40px 20px;
        color: #94a3b8;
    }

        .empty-basket span {
            font-size: 3rem;
        }

    .basket-footer {
        border-top: 1px solid #e2e8f0;
        padding: 12px 16px;
        background: white;
    }

    .basket-total {
        display: flex;
        justify-content: space-between;
        margin-bottom: 12px;
        font-weight: 600;
    }

    .total-price {
        color: #059669;
        font-size: 1.1rem;
    }

    .checkout-btn {
        width: 100%;
        background: linear-gradient(90deg, #10b981, #059669);
        color: white;
        border: none;
        padding: 10px;
        border-radius: 10px;
        cursor: pointer;
        font-weight: 600;
    }

        .checkout-btn:hover {
            opacity: 0.9;
        }
</style>
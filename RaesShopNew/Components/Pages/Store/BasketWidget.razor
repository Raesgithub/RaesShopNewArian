@using Application.Services
@inject BasketService Basket
@implements IDisposable
@inject NavigationManager NavigationManager

<div class="basket-widget">
    <button class="basket-button" @onclick="ToggleBasket">
        <span class="basket-icon">🛒</span>
        @if (Basket.TotalItemsCount > 0)
        {
            <span class="basket-badge">@Basket.TotalItemsCount</span>
        }
    </button>

    @if (IsOpen)
    {
        <div class="basket-dropdown">
            <div class="basket-header">
                <h3>سبد خرید</h3>
                @if (Basket.Items.Any())
                {
                    <button class="clear-basket" @onclick="ClearBasket">حذف همه</button>
                }
                <button class="close-basket" @onclick="ToggleBasket">✕</button>
            </div>

            @if (!Basket.Items.Any())
            {
                <div class="empty-basket">
                    <span>🛒</span>
                    <p>سبد خرید شما خالی است</p>
                </div>
            }
            else
            {
                <div class="basket-items">
                    @foreach (var item in Basket.Items)
                    {
                        <div class="basket-item">
                            <div class="item-image">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@GetFullImageUrl(item.ImageUrl)" alt="@item.Title" />
                                }
                                else
                                {
                                    <div class="no-image-small">📷</div>
                                }
                            </div>
                            <div class="item-details">
                                <div class="item-code">کد محصول: @item.Code</div>
                                <div class="item-title">@item.Title</div>
                                <div class="item-price-row">
                                    <span class="item-price">@item.Price.ToString("N0") تومان</span>
                                </div>
                                <div class="item-quantity">
                                    <button class="qty-btn" @onclick="() => DecrementQuantity(item.ProductId)">-</button>
                                    <span class="qty-value">@item.Quantity</span>
                                    <button class="qty-btn" @onclick="() => IncrementQuantity(item.ProductId)">+</button>
                                </div>
                            </div>
                            <button class="remove-item" @onclick="() => RemoveItem(item.ProductId)">🗑️</button>
                        </div>
                    }
                </div>
                <div class="basket-footer">
                    <div class="basket-total">
                        <span>مجموع:</span>
                        <span class="total-price">@Basket.TotalPrice.ToString("N0") تومان</span>
                    </div>
                    <button class="checkout-btn" @onclick="GoToCheckout">پرداخت</button>
                </div>
            }
        </div>
    }
</div>

@code {
    private bool IsOpen = false;
    private void GoToCheckout()
    {
        IsOpen = false;
        NavigationManager.NavigateTo("/checkout");
    }
    protected override void OnInitialized()
    {
        Basket.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Basket.OnChange -= StateHasChanged;
    }

    private void ToggleBasket() => IsOpen = !IsOpen;
    private void RemoveItem(int productId) => Basket.RemoveFromBasket(productId);

    private void IncrementQuantity(int productId)
    {
        var item = Basket.Items.FirstOrDefault(i => i.ProductId == productId);
        if (item != null) Basket.UpdateQuantity(productId, item.Quantity + 1);
    }

    private void DecrementQuantity(int productId)
    {
        var item = Basket.Items.FirstOrDefault(i => i.ProductId == productId);
        if (item != null) Basket.UpdateQuantity(productId, item.Quantity - 1);
    }

    private void ClearBasket() => Basket.ClearBasket();

    private string GetFullImageUrl(string? imageUrl)
    {
        if (string.IsNullOrEmpty(imageUrl)) return "/images/no-image.png";
        if (imageUrl.StartsWith("http")) return imageUrl;
        if (imageUrl.StartsWith("/")) return imageUrl;
        return $"/uploads/products/{imageUrl}";
    }
}

<style>
    .basket-widget {
        position: relative;
    }

    .basket-button {
        background: #fef3e2;
        border: none;
        padding: 8px 16px;
        border-radius: 40px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 1.2rem;
        position: relative;
        transition: all 0.2s;
        color: #e85d04;
    }

        .basket-button:hover {
            background: #fde6cc;
        }

    .basket-badge {
        background: #ef4444;
        color: white;
        border-radius: 50%;
        width: 20px;
        height: 20px;
        font-size: 0.7rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        position: absolute;
        top: -5px;
        left: -5px;
    }

    /* RTL fix: open to the left side */
    .basket-dropdown {
        position: absolute;
        top: 52px;
        right: 0;
        left: auto;
        width: 360px;
        max-height: 500px;
        background: white;
        border-radius: 16px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        border: 1px solid #f0e0d0;
        z-index: 2000;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .basket-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 16px;
        border-bottom: 1px solid #f0e0d0;
        background: #fffcf8;
    }

        .basket-header h3 {
            margin: 0;
            font-size: 1rem;
            color: #2d2a24;
        }

    .clear-basket {
        background: none;
        border: none;
        color: #ef4444;
        font-size: 0.8rem;
        cursor: pointer;
    }

    .close-basket {
        background: #f0ece6;
        border: none;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        font-size: 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

        .close-basket:hover {
            background: #e85d04;
            color: white;
        }

    .basket-items {
        flex: 1;
        overflow-y: auto;
        max-height: 350px;
    }

    .basket-item {
        display: flex;
        gap: 10px;
        padding: 10px 12px;
        border-bottom: 1px solid #fef3e2;
        position: relative;
        align-items: center;
    }

    .item-image {
        width: 52px;
        height: 52px;
        background: #fdf8f2;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        flex-shrink: 0;
    }

        .item-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .item-details {
        flex: 1;
        min-width: 0;
    }

    .item-code {
        font-size: 0.68rem;
        color: #78716c;
    }

    .item-title {
        font-weight: 600;
        font-size: 0.82rem;
        margin: 2px 0 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .item-price {
        font-weight: 700;
        color: #e85d04;
        font-size: 0.82rem;
    }

    .item-quantity {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-top: 4px;
    }

    .qty-btn {
        background: #fef3e2;
        border: none;
        width: 22px;
        height: 22px;
        border-radius: 6px;
        cursor: pointer;
        font-weight: bold;
        color: #e85d04;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .qty-btn:hover {
            background: #e85d04;
            color: white;
        }

    .qty-value {
        min-width: 20px;
        text-align: center;
        font-weight: 600;
        font-size: 0.85rem;
    }

    .remove-item {
        background: none;
        border: none;
        cursor: pointer;
        opacity: 0.4;
        transition: opacity 0.2s;
        font-size: 1rem;
        flex-shrink: 0;
    }

        .remove-item:hover {
            opacity: 1;
        }

    .empty-basket {
        text-align: center;
        padding: 40px 20px;
        color: #78716c;
    }

        .empty-basket span {
            font-size: 2.5rem;
        }

        .empty-basket p {
            margin-top: 10px;
            font-size: 0.9rem;
        }

    .basket-footer {
        border-top: 1px solid #f0e0d0;
        padding: 12px 16px;
        background: #fffcf8;
    }

    .basket-total {
        display: flex;
        justify-content: space-between;
        margin-bottom: 10px;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .total-price {
        color: #e85d04;
        font-size: 1rem;
        font-weight: 700;
    }

    .checkout-btn {
        width: 100%;
        background: linear-gradient(100deg, #e85d04, #ffb347);
        color: white;
        border: none;
        padding: 10px;
        border-radius: 10px;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.95rem;
        transition: opacity 0.2s;
    }

        .checkout-btn:hover {
            opacity: 0.9;
        }
</style>
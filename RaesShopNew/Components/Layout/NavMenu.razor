@using Application.Services
@using RaesShopNew.Components.Pages.Store
@inherits LayoutComponentBase
@rendermode InteractiveServer
@inject BasketService Basket
@inject SearchService SearchSvc


<div class="top-header">
    <div class="header-container">

        <!-- راست: همبرگر + برند -->
        <div class="header-right">
            <button class="menu-btn" id="menuBtn" onclick="toggleSidebar()">
                <span class="menu-icon">☰</span>
            </button>
            <div class="brand">
                <div class="brand-title">دیجی‌کالا</div>
                <div class="brand-sub">فروشگاه من</div>
            </div>
        </div>

        <!-- وسط: سرچ -->
        <div class="header-search">
            <input class="header-search-input"
                   placeholder="جستجوی محصول..."
                   value="@SearchSvc.SearchTerm"
                   @oninput="OnSearch"
                   @onkeydown="HandleKey" />
            <button class="header-search-btn" @onclick="DoSearch">جستجو</button>
        </div>

        <!-- چپ: پشتیبانی + سبد -->
        <div class="header-left">
            <div class="support-box">
                <div class="support-label">پشتیبانی</div>
                <div class="support-number">119</div>
            </div>
            <BasketWidget />
        </div>

    </div>
</div>
<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>
<div class="sidebar" id="sidebar">
    <div class="sidebar-header">
        <div class="sidebar-logo">
            <span>🛍️</span>
            <span>فروشگاه</span>
        </div>
        <button class="sidebar-close" onclick="closeSidebar()">✕</button>
    </div>

    <nav class="sidebar-nav">
        <a class="sidebar-link" href="stores">
            <span class="sidebar-icon">📋</span>
            <span>لیست محصولات</span>
        </a>
        <a class="sidebar-link" href="/">
            <span class="sidebar-icon">🏠</span>
            <span>فروشگاه</span>
        </a>
        <a class="sidebar-link" href="stores/add">
            <span class="sidebar-icon">➕</span>
            <span>محصول جدید</span>
        </a>
        <div class="sidebar-divider"></div>
        <a class="sidebar-link" href="#" onclick="alert('پشتیبانی: ۱۹۹'); return false;">
            <span class="sidebar-icon">🎧</span>
            <span>پشتیبانی</span>
        </a>
    </nav>

    <div class="sidebar-footer">
        <div class="sidebar-version">فروشگاه آنلاین</div>
    </div>
</div>

<style>
    :root {
        --orange: #e85d04;
        --orange-dark: #bb3e03;
        --orange-light: #ffb347;
        --orange-soft: #fef3e2;
        --text-dark: #2d2a24;
        --text-gray: #78716c;
        --border-light: #f0e0d0;
        --white: #ffffff;
        --sidebar-width: 280px;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
        background: #f5f5f0;
        font-family: 'Segoe UI', 'Inter', Tahoma, sans-serif;
    }

    .top-header {
        background: rgba(255,255,255,0.96);
        border-bottom: 1px solid var(--border-light);
        position: sticky;
        top: 0;
        z-index: 100;
        backdrop-filter: blur(8px);
        box-shadow: 0 1px 8px rgba(0,0,0,0.02);
    }

    .header-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 10px 24px;
        display: flex;
        justify-content: flex-start;
        align-items: center;
        gap: 16px;
    }

    .menu-btn {
        background: var(--orange-soft);
        border: none;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s;
        flex-shrink: 0;
    }

        .menu-btn:hover { background: #fde6cc; transform: scale(0.95); }

    .menu-icon { font-size: 24px; color: var(--orange); }

    .sidebar {
        position: fixed;
        top: 0;
        right: -320px;
        bottom: 0;
        width: var(--sidebar-width);
        background: linear-gradient(165deg, var(--white) 0%, #fefaf5 100%);
        box-shadow: -5px 0 25px rgba(0,0,0,0.1);
        transition: right 0.3s cubic-bezier(0.2, 0.9, 0.4, 1.1);
        z-index: 1001;
        display: flex;
        flex-direction: column;
        border-left: 1px solid var(--border-light);
    }

        .sidebar.open { right: 0; }

    .sidebar-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.4);
        backdrop-filter: blur(3px);
        z-index: 1000;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
    }

        .sidebar-overlay.active { opacity: 1; visibility: visible; }

    .sidebar-header {
        padding: 24px 20px;
        border-bottom: 2px solid var(--border-light);
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: linear-gradient(135deg, #fff9f0, var(--white));
    }

    .sidebar-logo {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 1.2rem;
        font-weight: 700;
        background: linear-gradient(135deg, var(--orange), var(--orange-light));
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
    }

        .sidebar-logo span:first-child { font-size: 1.5rem; }

    .sidebar-close {
        background: #f0ece6;
        border: none;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        font-size: 16px;
        cursor: pointer;
        color: #666;
        transition: all 0.25s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .sidebar-close:hover { background: var(--orange); color: white; transform: rotate(90deg); }

    .sidebar-nav {
        flex: 1;
        padding: 20px 16px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .sidebar-link {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 12px 16px;
        border-radius: 16px;
        color: var(--text-dark);
        text-decoration: none;
        font-weight: 500;
        transition: all 0.25s;
        font-size: 1rem;
    }

        .sidebar-link:hover {
            background: var(--orange-soft);
            color: var(--orange);
            transform: translateX(-5px);
        }

    .sidebar-icon { font-size: 1.2rem; width: 28px; text-align: center; }

    .sidebar-divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--border-light), transparent);
        margin: 16px 0;
    }

    .sidebar-footer {
        padding: 20px;
        border-top: 1px solid var(--border-light);
        text-align: center;
    }

    .sidebar-version { font-size: 0.75rem; color: var(--text-gray); }

    @@media (max-width: 768px) {
        .header-container { padding: 10px 16px; }
        .sidebar { width: 260px; }
    }
</style>
@code {
    private void OnSearch(ChangeEventArgs e)
    {
        SearchSvc.SearchTerm = e.Value?.ToString() ?? "";
    }

    private void DoSearch()
    {
        SearchSvc.SearchTerm = SearchSvc.SearchTerm;
    }

    private void HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") DoSearch();
    }

}
<style>
    .header-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 10px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
    }

    .header-right {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-shrink: 0;
    }

    .header-left {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-shrink: 0;
    }

    .brand {
        display: flex;
        flex-direction: column;
    }

    .brand-title {
        font-weight: 800;
        font-size: 1.1rem;
        background: linear-gradient(135deg, var(--orange), var(--orange-light));
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
        white-space: nowrap;
    }

    .brand-sub {
        font-size: 0.6rem;
        color: var(--orange-dark);
    }

    .header-search {
        display: flex;
        align-items: center;
        gap: 8px;
        flex: 1;
    }

    .header-search-input {
        flex: 1;
        padding: 10px 18px;
        border-radius: 50px;
        border: 1.5px solid var(--border-light);
        background: #fffcf8;
        outline: none;
        font-size: 0.9rem;
        font-family: inherit;
        transition: all 0.2s;
    }

        .header-search-input:focus {
            border-color: var(--orange);
            box-shadow: 0 0 0 3px rgba(232,93,4,0.1);
        }

    .header-search-btn {
        background: linear-gradient(100deg, var(--orange), var(--orange-light));
        color: white;
        padding: 10px 20px;
        border-radius: 50px;
        border: none;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.85rem;
        font-family: inherit;
        white-space: nowrap;
        transition: transform 0.2s;
    }

        .header-search-btn:hover {
            transform: scale(0.97);
        }

    .support-box {
        text-align: center;
        padding: 5px 14px;
        border-radius: 50px;
        background: #fef9f0;
        border: 1px solid var(--border-light);
        flex-shrink: 0;
    }

    .support-label {
        font-size: 0.62rem;
        color: var(--text-gray);
    }

    .support-number {
        font-weight: 800;
        color: var(--orange);
        font-size: 0.85rem;
    }

    @@media (max-width: 768px) {
        .header-container {
            padding: 8px 16px;
            gap: 8px;
        }

        .brand {
            display: none;
        }

        .support-box {
            display: none;
        }

        .header-search {
            flex: 1;
        }
    }
</style>
<script>
    function toggleSidebar() {
        var sidebar = document.getElementById('sidebar');
        var overlay = document.getElementById('sidebarOverlay');
        if (sidebar.classList.contains('open')) {
            sidebar.classList.remove('open');
            overlay.classList.remove('active');
        } else {
            sidebar.classList.add('open');
            overlay.classList.add('active');
        }
    }

    function closeSidebar() {
        document.getElementById('sidebar').classList.remove('open');
        document.getElementById('sidebarOverlay').classList.remove('active');
    }

    window.addEventListener('load', function () {
        document.querySelectorAll('.sidebar-link').forEach(function (link) {
            link.addEventListener('click', function () { setTimeout(closeSidebar, 150); });
        });
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') closeSidebar();
        });
    });
</script>